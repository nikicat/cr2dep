# Leave PRIVATE_KEY blank to sign via TronLink in your browser (browser-tron-signer).
# Set it to opt into local-key signing (CI / unattended use).
PRIVATE_KEY=
TRON_RPC=https://nile.trongrid.io
TRON_API_KEY=
# Override the network the browser signer connects to (mainnet | shasta | nile).
# If unset, inferred from TRON_RPC.
TRON_NETWORK=
# Optional: HTTP port the browser approval UI binds to (default 3848).
TRON_MCP_PORT=
# Optional: force the approval page to open in a specific browser (binary name or
# absolute path, e.g. "firefox", "google-chrome", "brave-browser"). Useful if your
# TronLink lives in a non-default browser. Defaults to the OS default browser.
BROWSER=
